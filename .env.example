# Eshu — Environment Configuration
# Copy this file to .env and fill in the required values.
#
# Required
# --------
ESHU_PROJECT_ID=my-project
ESHU_DATABASE_URL=postgresql://postgres:postgres@db:5432/eshu
OPENAI_API_KEY=sk-your-key-here

# Optional (defaults shown)
# --------
# ESHU_API_PORT=3100
# ESHU_API_KEY=
# ESHU_EMBEDDING_MODEL=text-embedding-3-small
# ESHU_SEARCH_THRESHOLD=0.25
# ESHU_SEARCH_LIMIT=20
